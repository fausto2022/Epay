# ============================================
# 彩虹易支付 Docker 部署 - 环境变量配置
# ============================================
# 使用前复制本文件为 .env 并修改以下配置：
#   cp env.example .env
#

# ---- MySQL 数据库配置 ----
# root 密码（仅用于容器内部维护，建议修改）
MYSQL_ROOT_PASSWORD=root2026secure

# 易支付使用的数据库名
MYSQL_DATABASE=epay

# 易支付数据库用户名
MYSQL_USER=epay

# 易支付数据库密码（务必修改为强密码）
MYSQL_PASSWORD=epay2026secure
